# Anthropic API Configuration
# Get your API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL — leave empty for official Anthropic API (default)
# LM Studio (local, free): http://127.0.0.1:1234
ANTHROPIC_BASE_URL=

# Model Configuration
# Main agent model
MAIN_MODEL=claude-sonnet-4-6
# Grader model (lighter model recommended for cost efficiency)
GRADER_MODEL=claude-haiku-4-5-20251001

# LangSmith Tracing (optional — recommended for LangGraph Studio)
# Get your API key at: https://smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=pilot-deepagents-rubrics
